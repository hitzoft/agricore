rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Match any document in any collection
    match /{collection}/{document} {
      allow read: if request.auth != null && (
        !('ownerId' in resource.data) || 
        resource.data.ownerId == request.auth.uid
      );
      
      allow write: if request.auth != null && (
        resource == null || 
        !('ownerId' in resource.data) || 
        resource.data.ownerId == request.auth.uid
      ) && (
        request.method == 'delete' ||
        request.resource.data.ownerId == request.auth.uid
      );
    }
    
    // Specifically protect global settings if any (none yet, but good practice)
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin (via console) can change global settings
    }
  }
}
